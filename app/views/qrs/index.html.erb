
<div class="content-container">
  <section class="mis-datos">
      <div class="header-qr">
        <h2>Gestión de QRs</h2>
        <div class="header-qr-buttons">
          <input type="text" id="qr_description" placeholder="Ingrese la descripción para crear nuevo QR" class="qr-input">
          <select id="companies" class="razon-social"></select>
          <button class="crear-qr-btn" onclick="create();">Crear</button> <!--Añadir accion para crear el QR-->
        </div>
      </div>
      <table class="table table-mis-datos ">
        <thead>
          <tr>
            <th class="mis-datos-first-th">Codigo</th>
            <th>Razón Social</th>
            <th>Descripción</th>
            <th>DJCs</th>
            <th class="mis-datos-last-th qrs-last-th">Acciones</th>
          </tr>
        </thead>
        <tbody>
          <% if @qrs.size > 0 %>
            <% @qrs.each do |qr| %>
              <tr id="qr_id_<%= qr.id %>"><!--variar la cantidad de QRs segun cantidad existente-->
                <td><%= qr.code %></td> <!-- traer codigo de QR-->
                <td><%= qr.company.name %></td><!-- traer Razon social de QR-->
                <td class="table_small_QRs"><%= qr.description %></td><!-- traer descripcion de QR-->
                <td><%= qr.djcs.count %></td><!-- traer los datos de cantidad de DJCs-->
                <td>
                  <div class="acciones-buttons">
                    <%= link_to 'Crear Nueva DJC', new_djc_path(company_id: qr.company_id, qr_id: qr.id), class: "btn btn-primary" %>
                    <%= link_to 'Descargar QR', qr_path(qr), class: "btn btn-secondary", target: "_blank" %>
                  </div>
                </td>
              </tr>
            <% end %>
          <% else %>
            <tr>
              <td colspan="5">
                Aún no hay QRs.
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
  </section>
</div>

<script>
$(document).ready(function() {
  loadCompanies();
});

async function loadCompanies() {
  // Mostrar el mensaje de "Cargando compañías..." al inicio
  createApiResponse("info", {message: "Cargando Razones Sociales..."})

  r = await doGet("<%= api_v1_companies_url %>");
  if(r != null) {

    $('#companies').empty();
    if(r.length == 1) {
      $("#companies").append(`<option value="${r[0].id}" selected="true">${r[0].name}</option>`);
    }
    else {
      $("#companies").append('<option value="">Seleccione una Razón Social</option>')
      // Iterar sobre la lista de compañías y agregar cada una como opción
      $.each(r, (index, company) => {
        $("#companies").append('<option value="' + company.id + '">' + company.name + '</option>');
      });
      $('#companies').one('change', function() {
        $('#companies option[value=""]').remove();
      });
    }
    cleanApiResponse();
  }
}
async function create() {
  const company_id = $("#companies").val();
  if(company_id == "") {
    createApiResponse("warning", {message: "Debe seleccionar una Razón Social"});
    return;
  }
  const description = $("#qr_description").val();
  if(description == "") {
    createApiResponse("warning", {message: "Debe ingresar una descripción"});
    return;
  }
  
  createApiResponse("info", {message: "Creando nuevo QR..."});
  qr = await doPost("<%= api_v1_qrs_url %>", {
    description: description,
    company_id: company_id
  });
  if(qr != null) {
    $("#qr_description").val("");
  }
}

</script>