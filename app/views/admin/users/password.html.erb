<div class="container-mis-datos">
  <section class="mis-datos editar-mis-datos">
      <h2>Cambiar contraseña</h2>
      <%= form_with model: [:admin, @user], local: true, html: { class: "form-editar-datos form-editar-pwd" } do |form| %>
        <div class="form-group form-group-pwd">
          <label for="pwd-actual">Contraseña actual:</label>
          <%= form.password_field :current_password, id: "pwd-actual", class: "form-control", placeholder: "Ingrese su contraseña actual", required: true %>
        </div>
        <div class="form-group form-group-pwd">
          <label for="pwd-nueva">Nueva contraseña:</label>
          <%= form.password_field :password, id: "pwd-nueva", class: "form-control", placeholder: "Ingrese la nueva contraseña", required: true %>
        </div>
        <div class="form-group form-group-pwd">
          <label for="pwd-nueva-2">Confirmación de nueva contraseña:</label>
          <%= form.password_field :password_confirmation, id: "pwd-nueva-2", class: "form-control", placeholder: "Confirme la nueva contraseña", required: true %>
        </div>
        <div class="form-actions">
          <%= form.submit "Guardar Cambios", class: "btn-submit" %>
          <%= link_to 'Cancelar', admin_users_path, class: 'volver' %>
        </div>
      <% end %>
      <div class="aviso"><i class="fa-solid fa-circle-info"></i>Al actualizar la contraseña debera volver a ingresar</div>
  </section>
</div>